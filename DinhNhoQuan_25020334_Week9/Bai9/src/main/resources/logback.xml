<configuration>

    <!-- 1. ConsoleAppender: In log ra màn hình Terminal -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Định dạng: Thời gian [Thread] LEVEL Tên_Class - Nội_dung -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2. FileAppender: Lưu log vào tệp vật lý -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/application.log</file> <!-- Đường dẫn lưu tệp -->
        <append>true</append> <!-- Ghi tiếp vào file cũ thay vì ghi đè -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Gắn appender vào thư mục gốc với mức độ hiển thị từ INFO trở lên -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE" />
    </root>

</configuration>